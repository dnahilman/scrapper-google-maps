#!/usr/bin/env bash
# Helper untuk scrapper container — dual-mode (LOCAL default, --vps untuk remote).
#
# LOCAL MODE (default):
#   Pre-req: docker compose -f docker-compose.dev.yml up -d --build  (sekali)
#   ./scr scrape cafe --kelurahan "Cihapit"
#
# VPS MODE (prefix --vps):
#   Pre-req: export VPS_HOST=user@host
#   ./scr --vps scrape cafe
#
# Actions yang butuh <keyword>:
#   scrape <keyword> [args]   - START scrape di BACKGROUND (detached)
#   sync   <keyword> [args]   - manual sync (foreground)
#   status <keyword>          - cek progress + sync summary untuk keyword
#   pull   <keyword>          - download data dari VPS (vps mode only)
#
# Actions tanpa keyword:
#   stop          - kill background scrape process
#   is-running    - cek apakah scrape sedang berjalan
#   logs          - tail latest python log file (Ctrl+C exit)
#   shell         - bash di container
#   ps            - container status
#   redeploy      - LOCAL: rebuild image. VPS: pull image baru + restart

set -e

# ============================================================================
# Mode detection: --vps as first arg → remote; else local docker compose dev.
# ============================================================================
MODE="local"
if [ "${1:-}" = "--vps" ]; then
  MODE="vps"
  shift
fi

DEV_SERVICE="scraper"

if [ "$MODE" = "local" ]; then
  # Auto-detect compose tool: prefer 'docker compose', fallback ke 'podman-compose'.
  # Override paksa: COMPOSE_TOOL=docker ./scr ... atau COMPOSE_TOOL=podman ./scr ...
  DEV_COMPOSE_CMD=""
  case "${COMPOSE_TOOL:-}" in
    docker) DEV_COMPOSE_CMD="docker compose" ;;
    podman) DEV_COMPOSE_CMD="podman-compose" ;;
    "")
      if docker compose version >/dev/null 2>&1; then
        DEV_COMPOSE_CMD="docker compose"
      elif command -v podman-compose >/dev/null 2>&1; then
        DEV_COMPOSE_CMD="podman-compose"
      fi
      ;;
    *)
      echo "ERROR: COMPOSE_TOOL='$COMPOSE_TOOL' tidak valid. Pakai 'docker' atau 'podman'." >&2
      exit 1
      ;;
  esac

  if [ -z "$DEV_COMPOSE_CMD" ]; then
    echo "ERROR: 'docker compose' atau 'podman-compose' tidak ditemukan di PATH." >&2
    echo "Install salah satu:" >&2
    echo "  - Docker Desktop (compose plugin built-in)" >&2
    echo "  - podman + podman-compose (pip install podman-compose)" >&2
    exit 1
  fi
  DEV_COMPOSE="$DEV_COMPOSE_CMD -f docker-compose.dev.yml"
fi

if [ "$MODE" = "vps" ]; then
  : "${VPS_HOST:?Set VPS_HOST=user@host (mis. dios@182.23.12.142)}"
  PROJ_DIR="${VPS_PROJ_DIR:-/opt/scrapper-google-maps}"
  PROD_CONTAINER="scrapper-prod"
  PROD_COMPOSE="docker compose -f $PROJ_DIR/docker-compose.prod.yml"
fi

cmd="${1:-help}"
shift || true

# Prefix string untuk pesan help (tampilkan --vps di contoh kalau lagi vps mode).
mode_prefix=""
[ "$MODE" = "vps" ] && mode_prefix="--vps "

require_keyword() {
  if [ -z "$1" ]; then
    echo "ERROR: action '$cmd' butuh <keyword> sebagai argumen pertama." >&2
    echo "Contoh: $0 ${mode_prefix}$cmd cafe" >&2
    exit 1
  fi
}

case "$cmd" in
  status)
    KEYWORD="${1:-}"; require_keyword "$KEYWORD"; shift || true
    PY="import config; config.set_keyword('$KEYWORD'); from src.storage import progress_summary, sync_summary; print('keyword:', config.get_keyword()); print('scrape:', progress_summary()); print('sync:', sync_summary())"
    if [ "$MODE" = "vps" ]; then
      ssh "$VPS_HOST" "docker exec -i $PROD_CONTAINER python -c \"$PY\""
    else
      $DEV_COMPOSE exec -T $DEV_SERVICE python -c "$PY"
    fi
    ;;
  scrape)
    KEYWORD="${1:-}"; require_keyword "$KEYWORD"; shift || true
    # Auto-detect: kalau user pass --kelurahan X (re-scrape spesifik), skip --resume.
    # Full run (tanpa --kelurahan) → --resume tetap on supaya skip kelurahan yang done.
    if [[ "$*" == *"--kelurahan"* ]]; then
      RESUME_FLAG=""
      RESUME_NOTE="re-scrape mode (--kelurahan filter, no --resume)"
    else
      RESUME_FLAG="--resume"
      RESUME_NOTE="resume mode (skip kelurahan yang sudah done)"
    fi
    if [ "$MODE" = "vps" ]; then
      ssh "$VPS_HOST" "docker exec -d $PROD_CONTAINER python scripts/scraper.py --keyword $KEYWORD $RESUME_FLAG $*"
      echo ""
      echo "[OK] Scraper started in BACKGROUND (detached) — keyword=$KEYWORD (VPS)"
      echo "    $RESUME_NOTE"
      echo "Anda boleh close terminal / shutdown laptop. Scrape jalan di VPS."
    else
      $DEV_COMPOSE exec -d $DEV_SERVICE python scripts/scraper.py --keyword $KEYWORD $RESUME_FLAG $*
      echo ""
      echo "[OK] Scraper started in BACKGROUND (detached) — keyword=$KEYWORD (LOCAL)"
      echo "    $RESUME_NOTE"
      echo "Process jalan di container local. Container restart akan kill process."
    fi
    echo "    Sync: opt-in via --auto-sync (butuh GOOGLE_MAPS_SYNC_API_KEY di .env.local)"
    echo ""
    echo "Monitor:"
    echo "  $0 ${mode_prefix}logs                # tail log realtime"
    echo "  $0 ${mode_prefix}status $KEYWORD     # progress count"
    echo "  $0 ${mode_prefix}is-running          # cek alive"
    echo "  $0 ${mode_prefix}stop                # kill graceful"
    ;;
  stop)
    if [ "$MODE" = "vps" ]; then
      ssh "$VPS_HOST" "docker exec $PROD_CONTAINER pkill -f 'scripts/scraper.py' 2>/dev/null && echo '[OK] Scraper stopped' || echo '[--] Tidak ada scraper berjalan'"
    else
      $DEV_COMPOSE exec -T $DEV_SERVICE bash -c "pkill -f 'scripts/scraper.py' 2>/dev/null && echo '[OK] Scraper stopped' || echo '[--] Tidak ada scraper berjalan'"
    fi
    ;;
  is-running)
    if [ "$MODE" = "vps" ]; then
      if ssh "$VPS_HOST" "docker exec $PROD_CONTAINER pgrep -af 'scripts/scraper.py' 2>/dev/null"; then
        echo "[RUNNING]"
      else
        echo "[STOPPED]"
      fi
    else
      if $DEV_COMPOSE exec -T $DEV_SERVICE pgrep -af 'scripts/scraper.py' 2>/dev/null; then
        echo "[RUNNING]"
      else
        echo "[STOPPED]"
      fi
    fi
    ;;
  logs)
    if [ "$MODE" = "vps" ]; then
      ssh -t "$VPS_HOST" "docker exec -t $PROD_CONTAINER bash -c 'F=\$(ls -t /app/logs/scraper-*.log 2>/dev/null | head -1); [ -n \"\$F\" ] && tail -f -n 100 \"\$F\" || echo \"No log files yet\"'"
    else
      $DEV_COMPOSE exec $DEV_SERVICE bash -c 'F=$(ls -t /app/logs/scraper-*.log 2>/dev/null | head -1); [ -n "$F" ] && tail -f -n 100 "$F" || echo "No log files yet"'
    fi
    ;;
  sync)
    KEYWORD="${1:-}"; require_keyword "$KEYWORD"; shift || true
    if [ "$MODE" = "vps" ]; then
      ssh -t "$VPS_HOST" "docker exec -it $PROD_CONTAINER python scripts/sync.py --keyword $KEYWORD $*"
    else
      $DEV_COMPOSE exec $DEV_SERVICE python scripts/sync.py --keyword $KEYWORD $*
    fi
    ;;
  shell)
    if [ "$MODE" = "vps" ]; then
      ssh -t "$VPS_HOST" "docker exec -it $PROD_CONTAINER bash"
    else
      $DEV_COMPOSE exec $DEV_SERVICE bash
    fi
    ;;
  pull)
    KEYWORD="${1:-}"; require_keyword "$KEYWORD"; shift || true
    if [ "$MODE" = "vps" ]; then
      mkdir -p "./data/${KEYWORD}-from-vps"
      rsync -avz --progress "$VPS_HOST:$PROJ_DIR/data/$KEYWORD/" "./data/${KEYWORD}-from-vps/"
    else
      echo "[--] Local mode: data sudah di ./data/$KEYWORD/ (volume-mounted dari container)."
      echo "    Tidak perlu pull."
    fi
    ;;
  ps)
    if [ "$MODE" = "vps" ]; then
      ssh "$VPS_HOST" "$PROD_COMPOSE ps"
    else
      $DEV_COMPOSE ps
    fi
    ;;
  redeploy)
    if [ "$MODE" = "vps" ]; then
      ssh "$VPS_HOST" "$PROD_COMPOSE pull && $PROD_COMPOSE up -d && $PROD_COMPOSE ps"
    else
      $DEV_COMPOSE build && $DEV_COMPOSE up -d && $DEV_COMPOSE ps
    fi
    ;;
  help|--help|-h|*)
    echo "Usage: $0 [--vps] {action} [keyword] [args...]"
    echo ""
    echo "Mode:"
    echo "  (default)    LOCAL — auto-detect 'docker compose' / 'podman-compose' (override: COMPOSE_TOOL=docker|podman)"
    echo "  --vps        VPS   — ssh \$VPS_HOST + docker exec scrapper-prod"
    echo ""
    echo "Actions yang butuh <keyword>:"
    echo "  scrape <keyword> [args]   Start scrape di BACKGROUND (detached)"
    echo "  sync   <keyword> [args]   Manual sync (foreground)"
    echo "  status <keyword>          Progress + sync summary"
    echo "  pull   <keyword>          Download data dari VPS (vps mode only)"
    echo ""
    echo "Actions tanpa keyword:"
    echo "  stop         Kill background scrape"
    echo "  is-running   Cek apakah scrape jalan"
    echo "  logs         Tail log file realtime"
    echo "  shell        Bash di container"
    echo "  ps           Container status"
    echo "  redeploy     LOCAL: rebuild image. VPS: pull & restart"
    echo ""
    echo "Local pre-req (sekali):"
    echo "  docker compose -f docker-compose.dev.yml up -d --build"
    echo ""
    echo "VPS pre-req:"
    echo "  export VPS_HOST=user@host    # mis. dios@182.23.12.142"
    echo ""
    echo "Examples:"
    echo "  $0 scrape cafe                                       # scrape only, no sync"
    echo "  $0 scrape cafe --auto-sync                           # + auto-sync (butuh API key)"
    echo "  $0 scrape cafe --kelurahan \"Cihapit\"                 # re-scrape spesifik (no resume)"
    echo "  $0 sync cafe --all --force                           # manual sync semua file"
    echo "  $0 status cafe                                       # progress + sync summary"
    echo "  $0 --vps scrape cafe --auto-sync                     # remote full run"
    echo "  $0 --vps status cafe                                 # remote status"
    [ "$cmd" = "help" ] || [ "$cmd" = "--help" ] || [ "$cmd" = "-h" ] || exit 1
    ;;
esac
