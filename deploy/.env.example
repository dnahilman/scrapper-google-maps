# Copy ke .env lalu isi nilainya. File .env masuk .gitignore — jangan commit.

# PostgreSQL
POSTGRES_PASSWORD=changeme

# Master
MASTER_TOKEN=replace-with-strong-random-token
LOG_LEVEL=info
LOG_FORMAT=console
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Worker
WORKER_NAME=local-worker
MAX_CONCURRENCY=2
HEADLESS=true
MIN_DELAY_SEC=8
MAX_DELAY_SEC=20

# Image tag (kosongkan untuk build lokal / default dev)
TAG=dev
