#!/usr/bin/env bash
# Helper untuk scrapper container di VPS via SSH (bash version).
#
# Setup (sekali):
#   chmod +x bin/scrapper-vps
#   export VPS_HOST=dios@182.23.12.142     # taruh di ~/.bashrc untuk persistent
#   export KEYWORD=cafe                    # target scraping (default: cafe)
#
# Actions:
#   status       - cek progress + sync summary
#   scrape       - START scrape di BACKGROUND (detached, SSH close OK)
#   stop         - kill background scrape process
#   is-running   - cek apakah scrape sedang berjalan
#   logs         - tail latest python log file (Ctrl+C exit)
#   sync         - manual sync (foreground)
#   shell        - bash di container
#   ps           - container status
#   pull         - download data dari VPS ke laptop
#   redeploy     - force pull image baru + restart

set -e

VPS_HOST="${VPS_HOST:?Set VPS_HOST=user@host (mis. dios@182.23.12.142)}"
PROJ_DIR="${VPS_PROJ_DIR:-/opt/scrapper-google-maps}"
CONTAINER="scrapper-prod"
COMPOSE="docker compose -f $PROJ_DIR/docker-compose.prod.yml"
KEYWORD="${KEYWORD:-cafe}"

cmd="${1:-help}"
shift || true

case "$cmd" in
  status)
    ssh "$VPS_HOST" "docker exec -e KEYWORD=$KEYWORD -i $CONTAINER python -c \"from config import KEYWORD; from src.storage import progress_summary, sync_summary; print('keyword:', KEYWORD); print('scrape:', progress_summary()); print('sync:', sync_summary())\""
    ;;
  scrape)
    # Detached: process tetap jalan walau SSH close
    ssh "$VPS_HOST" "docker exec -d -e KEYWORD=$KEYWORD $CONTAINER python scripts/scraper.py --resume --auto-sync $*"
    echo ""
    echo "[OK] Scraper started in BACKGROUND (detached) — keyword=$KEYWORD"
    echo "Anda boleh close terminal / shutdown laptop. Scrape jalan di VPS."
    echo ""
    echo "Monitor:"
    echo "  $0 logs        # tail log realtime"
    echo "  $0 status      # progress count"
    echo "  $0 is-running  # cek alive"
    echo "  $0 stop        # kill graceful"
    ;;
  stop)
    ssh "$VPS_HOST" "docker exec $CONTAINER pkill -f 'scripts/scraper.py' 2>/dev/null && echo '[OK] Scraper stopped' || echo '[--] Tidak ada scraper berjalan'"
    ;;
  is-running)
    if ssh "$VPS_HOST" "docker exec $CONTAINER pgrep -af 'scripts/scraper.py' 2>/dev/null"; then
      echo "[RUNNING]"
    else
      echo "[STOPPED]"
    fi
    ;;
  logs)
    ssh -t "$VPS_HOST" "docker exec -t $CONTAINER bash -c 'F=\$(ls -t /app/logs/scraper-*.log 2>/dev/null | head -1); [ -n \"\$F\" ] && tail -f -n 100 \"\$F\" || echo \"No log files yet\"'"
    ;;
  sync)
    ssh -t "$VPS_HOST" "docker exec -e KEYWORD=$KEYWORD -it $CONTAINER python scripts/sync.py $*"
    ;;
  shell)
    ssh -t "$VPS_HOST" "docker exec -e KEYWORD=$KEYWORD -it $CONTAINER bash"
    ;;
  pull)
    mkdir -p "./data/${KEYWORD}-from-vps"
    rsync -avz --progress "$VPS_HOST:$PROJ_DIR/data/$KEYWORD/" "./data/${KEYWORD}-from-vps/"
    ;;
  ps)
    ssh "$VPS_HOST" "$COMPOSE ps"
    ;;
  redeploy)
    ssh "$VPS_HOST" "$COMPOSE pull && $COMPOSE up -d && $COMPOSE ps"
    ;;
  help|--help|-h|*)
    echo "Usage: $0 {action} [args...]"
    echo ""
    echo "Actions:"
    echo "  scrape       Start scrape di BACKGROUND (default, detached)"
    echo "  stop         Kill background scrape"
    echo "  is-running   Cek apakah scrape jalan"
    echo "  logs         Tail log file realtime"
    echo "  status       Progress + sync summary"
    echo "  sync         Manual sync (foreground)"
    echo "  shell        Bash di container"
    echo "  ps           Container status"
    echo "  pull         Download data ke laptop"
    echo "  redeploy     Force pull image baru"
    echo ""
    echo "Env:"
    echo "  KEYWORD=cafe (default) — set ke 'barbershop', 'kuliner', dll"
    echo ""
    echo "Examples:"
    echo "  $0 scrape"
    echo "  KEYWORD=barbershop $0 scrape --kelurahan \"Cihapit\""
    echo "  $0 sync --all --force"
    [ "$cmd" = "help" ] || [ "$cmd" = "--help" ] || [ "$cmd" = "-h" ] || exit 1
    ;;
esac
