# Copy file ini ke .env.local lalu isi credential asli.
# .env.local masuk .gitignore, jangan commit.
#
# Compose dev/prod baca file ini lewat `env_file: .env.local` — value di-inject
# sebagai env var ke container saat runtime (no build-time bake).

# Endpoint utama (JSON, header x-api-key, body { cafes: [...] }).
CAFES_SYNC_URL=https://api.example.com/api/v1/sync/cafes

# API key dipakai sebagai header x-api-key ke CAFES_SYNC_URL.
# Dapatkan dari admin backend.
GOOGLE_MAPS_SYNC_API_KEY=your_api_key_here

# Legacy (multipart) — opsional, hanya kalau pakai endpoint lama.
APP_URL=https://api.example.com/api

# ===== Go rewrite (scrapper-go) =====

# PostgreSQL
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://scrapper:changeme@postgres:5432/scrapper?sslmode=disable

# Master
HTTP_ADDR=:8080
LOG_LEVEL=info
MASTER_TOKEN=replace-with-strong-random-token

# External sync target (gosom-style payload)
SYNC_API_URL=
SYNC_API_KEY=

# Emsifa (Indonesia wilayah API)
EMSIFA_BASE_URL=https://emsifa.github.io/api-wilayah-indonesia/api

# Worker
MASTER_URL=http://master:8080
WORKER_NAME=local-worker
MAX_CONCURRENCY=2
HEADLESS=true
MIN_DELAY_SEC=10
MAX_DELAY_SEC=25
MAX_REVIEWS_PER_PLACE=200
