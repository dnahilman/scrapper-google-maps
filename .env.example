# Copy file ini ke .env.local lalu isi credential asli.
# .env.local masuk .gitignore, jangan commit.
#
# Compose dev/prod baca file ini lewat `env_file: .env.local` — value di-inject
# sebagai env var ke container saat runtime (no build-time bake).

# Backend API target untuk POST hasil scraping
APP_URL=https://api.example.com/api

# API key untuk endpoint /v1/web/sync-google-maps
# Dapatkan dari admin backend.
GOOGLE_MAPS_SYNC_API_KEY=your_api_key_here
